{
  "name": "mi-app-expo-rn",
  "version": "1.1.0",
  "private": true,
  "main": "index.js",
  "description": "Aplicación accesible implementada con Expo y React Native, preparada para generar APK con EAS Build.",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "web": "expo start --web",
    "doctor": "npx expo-doctor",
    "export:android": "npx expo export --platform android",
    "apk": "eas build -p android --profile preview",
    "apk:clear": "eas build -p android --profile preview --clear-cache",
    "apk:local": "eas build -p android --profile preview --local"
  },
  "dependencies": {
    "babel-preset-expo": "~57.0.0",
    "expo": "~57.0.0",
    "expo-clipboard": "~57.0.0",
    "expo-document-picker": "~57.0.0",
    "expo-file-system": "~57.0.0",
    "expo-image-picker": "~57.0.0",
    "expo-speech": "~57.0.0",
    "expo-speech-recognition": "^56.0.1",
    "expo-text-extractor": "^2.0.0",
    "react": "19.2.3",
    "react-native": "0.86.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2"
  }
}
